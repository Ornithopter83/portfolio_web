@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS

@if (IsOpen)
{
    <div class="demo-launcher" role="dialog" aria-modal="true" aria-labelledby="demo-launcher-title">
        <div class="demo-launcher__header">
            <div>
                <p class="eyebrow">Interactive demo launcher</p>
                <h2 id="demo-launcher-title">시연</h2>
            </div>
            <button type="button" class="icon-button" aria-label="닫기" @onclick="CloseAsync">×</button>
        </div>

        <div class="demo-launcher__body">
            <section class="demo-launcher__stage" aria-label="3D preview">
                <canvas id="@CanvasId"></canvas>
            </section>

            <section class="demo-launcher__controls" aria-label="Demo list">
                @foreach (var demo in Demos)
                {
                    <button type="button"
                            class="demo-button @(selectedDemo.Key == demo.Key ? "is-selected" : null)"
                            @onclick="() => SelectDemo(demo)">
                        @demo.Title
                    </button>
                }
            </section>
        </div>

        <p class="demo-launcher__description">@selectedDemo.Description</p>
    </div>
}

@code {
    private const string CanvasId = "demo-launcher-canvas";
    private IJSObjectReference? module;
    private DotNetObjectReference<DemoLauncherModal>? dotNetReference;
    private DemoItem selectedDemo = Demos[0];

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    private static readonly DemoItem[] Demos =
    [
        new("ocr", "OCR 시연", "이미지나 문서에서 텍스트를 추출하고 검수 흐름으로 넘기는 OCR 데모 자리입니다."),
        new("automation", "업무 자동화", "반복 업무를 수집, 분류, 실행하는 자동화 파이프라인 데모 자리입니다."),
        new("nas", "NAS 웹서비스", "NAS 정적 호스팅과 내부 서비스 연결 흐름을 보여줄 데모 자리입니다."),
        new("supabase", "Supabase 연동", "Supabase 인증, 데이터 조회, 이벤트 기록을 연결할 데모 자리입니다.")
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsOpen)
        {
            return;
        }

        module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/demoLauncher3d.js");
        dotNetReference ??= DotNetObjectReference.Create(this);

        await module.InvokeVoidAsync("startDemoLauncher", CanvasId);
        await module.InvokeVoidAsync("registerEscapeClose", dotNetReference);
    }

    private void SelectDemo(DemoItem demo)
    {
        selectedDemo = demo;
    }

    private async Task CloseAsync()
    {
        if (module is not null)
        {
            await module.InvokeVoidAsync("stopDemoLauncher");
            await module.InvokeVoidAsync("unregisterEscapeClose");
        }

        await IsOpenChanged.InvokeAsync(false);
    }

    [JSInvokable]
    public Task CloseFromEscape()
    {
        return CloseAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            await module.InvokeVoidAsync("stopDemoLauncher");
            await module.InvokeVoidAsync("unregisterEscapeClose");
            await module.DisposeAsync();
        }

        dotNetReference?.Dispose();
    }

    private sealed record DemoItem(string Key, string Title, string Description);
}
