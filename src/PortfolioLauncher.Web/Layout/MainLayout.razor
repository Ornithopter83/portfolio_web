@inherits LayoutComponentBase
@using PortfolioLauncher.Web.Components

<div class="app-shell">
    <header class="site-header">
        <NavMenu OnDemoRequested="OpenDemoLauncher" />
    </header>

    <main class="site-main">
        @Body
    </main>
</div>

<DemoLauncherModal @bind-IsOpen="isDemoLauncherOpen" />

@code {
    private bool isDemoLauncherOpen;

    private void OpenDemoLauncher()
    {
        isDemoLauncherOpen = true;
    }
}
